---
import { ui } from "../i18n/ui";
---

<footer class="border-t border-gray-200 dark:border-gray-700 mt-auto">
  <div class="max-w-4xl mx-auto px-4 py-6 flex flex-col items-center gap-3 text-sm text-gray-500 dark:text-gray-400">
    <span>{ui.site.name}</span>
    <span>{ui.site.copyright}</span>
    <div class="flex items-center gap-4">
      <a href="https://github.com/melyuh" target="_blank" rel="noopener" aria-label="GitHub">GitHub</a>
      <a href="https://linkedin.com/in/melyuh" target="_blank" rel="noopener" aria-label="LinkedIn">LinkedIn</a>
      <a href="/rss.xml" aria-label="RSS">{ui.footer.rss}</a>
    </div>
  </div>
</footer>
